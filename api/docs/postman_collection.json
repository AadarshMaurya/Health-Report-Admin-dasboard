      "name": "Authentication",
      "item": [
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clinitech.com\",\n  \"password\": \"AdminPassword123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Exchanges email and password credentials for standard JWT access and refresh tokens."
          },
          "response": []
        },
        {
          "name": "Token Refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"YOUR_REFRESH_TOKEN_HERE\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/refresh",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Requests a new short-lived access token using a valid, active refresh token."
          },
          "response": []
        }
      ]
